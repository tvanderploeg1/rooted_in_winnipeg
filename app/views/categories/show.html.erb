<section class="section">
  <div class="container">
    <h1 class="title"><%= @category.name %></h1>
    <p class="subtitle">Plants in this category.</p>
    <p class="mb-4"><strong><%= pluralize(@products.total_count, "product") %></strong> found</p>

    <%= render "shared/product_results",
        products: @products,
        show_category: false,
        show_add_to_cart: false,
        top_margin_class: "",
        empty_message: "No products matched your filters. Try a different search or category." %>

    <div class="mt-4">
      <%= link_to "Back to all products", products_path, class: "button is-link is-light" %>
    </div>
  </div>
</section>
