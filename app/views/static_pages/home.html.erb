<section class="hero is-success is-small">
  <div class="hero-body">
    <div class="container">
      <h1 class="title">Rooted in Winnipeg</h1>
      <p class="subtitle">Local and climate-appropriate plants for Winnipeg homes and gardens.</p>
      <div class="buttons mt-4">
        <%= link_to "Browse Products", "#", class: "button is-light" %>
        <%= link_to "About This Project", about_path, class: "button is-outlined is-light" %>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="columns">
      <div class="column">
        <div class="box">
          <h2 class="title is-5">Local Focus</h2>
          <p>Plant selections suited for Manitoba growing conditions.</p>
        </div>
      </div>
      <div class="column">
        <div class="box">
          <h2 class="title is-5">Real Product Data</h2>
          <p>Seeded from real-world plant information for realistic browsing.</p>
        </div>
      </div>
      <div class="column">
        <div class="box">
          <h2 class="title is-5">Secure Checkout</h2>
          <p>Customer login, cart, and payment flow built with Rails conventions.</p>
        </div>
      </div>
    </div>
  </div>
</section>
